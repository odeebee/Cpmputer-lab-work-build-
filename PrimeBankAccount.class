/*
    ATM Bank Simulator Stylesheet
    Dark neon ATM theme
*/

.root {
    -fx-background-color: linear-gradient(to bottom right, #020617, #0f172a);
    -fx-font-family: "Segoe UI", Arial, sans-serif;
}

#Layout {
    -fx-background-color: linear-gradient(to bottom right, #020617, #111827);
    -fx-padding: 18px;
    -fx-hgap: 10px;
    -fx-vgap: 14px;
}

#titleLabel {
    -fx-text-fill: #38bdf8;
    -fx-font-size: 30px;
    -fx-font-weight: bold;
    -fx-padding: 10px 0 10px 10px;
    -fx-effect: dropshadow(gaussian, rgba(56, 189, 248, 0.75), 14, 0.6, 0, 0);
}

.text-field {
    -fx-background-color: #020617;
    -fx-text-fill: #38bdf8;
    -fx-prompt-text-fill: #64748b;
    -fx-border-color: #93c5fd;
    -fx-border-width: 1.5px;
    -fx-border-radius: 10px;
    -fx-background-radius: 10px;
    -fx-padding: 10px;
    -fx-font-size: 18px;
}

.text-area {
    -fx-background-color: #020617;
    -fx-text-fill: #86efac;
    -fx-font-size: 20px;
    -fx-font-weight: bold;
    -fx-border-color: #22c55e;
    -fx-border-width: 2px;
    -fx-border-radius: 12px;
    -fx-background-radius: 12px;
    -fx-effect: dropshadow(gaussian, rgba(34, 197, 94, 0.45), 12, 0.4, 0, 0);
}

.text-area .content {
    -fx-background-color: #020617;
}

.scroll-pane {
    -fx-background-color: transparent;
    -fx-border-color: transparent;
}

.scroll-pane .viewport {
    -fx-background-color: transparent;
}

#Buttons {
    -fx-hgap: 14px;
    -fx-vgap: 12px;
    -fx-padding: 10px 0 0 0;
}

.button {
    -fx-text-fill: #f8fafc;
    -fx-font-size: 18px;
    -fx-font-weight: bold;
    -fx-border-color: #93c5fd;
    -fx-border-width: 1px;
    -fx-cursor: hand;
}

.button:hover {
    -fx-effect: dropshadow(gaussian, rgba(59, 130, 246, 0.85), 16, 0.6, 0, 0);
}

.button:pressed {
    -fx-scale-x: 0.95;
    -fx-scale-y: 0.95;
}

/* Number buttons */
#numberButton {
    -fx-background-color: linear-gradient(to bottom, #475569, #1e293b);
    -fx-background-radius: 50%;
    -fx-border-radius: 50%;
}

/* Action buttons */
#depositButton,
#withdrawButton,
#balanceButton,
#passwordButton,
#enterButton,
#finishButton,
#clearButton {
    -fx-background-radius: 14px;
    -fx-border-radius: 14px;
    -fx-padding: 10px 18px;
}

/* Blue action buttons */
#depositButton,
#withdrawButton,
#balanceButton,
#passwordButton,
#loginButton {
    -fx-background-color: linear-gradient(to bottom, #2563eb, #1e40af);
}

/* Green confirm buttons */
#enterButton,
#finishButton {
    -fx-background-color: linear-gradient(to bottom, #22c55e, #15803d);
}

/* Red clear button */
#clearButton {
    -fx-background-color: linear-gradient(to bottom, #ef4444, #991b1b);
    -fx-background-radius: 14px;
    -fx-border-radius: 14px;
}

/* Create account button */
#createAccountButton {
    -fx-background-color: linear-gradient(to bottom, #7c3aed, #4c1d95);
    -fx-background-radius: 14px;
    -fx-border-radius: 14px;
    -fx-padding: 14px 28px;
}

/* Login button */
#loginButton {
    -fx-background-radius: 14px;
    -fx-border-radius: 14px;
    -fx-padding: 14px 28px;
}
